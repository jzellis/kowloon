# Kowloon Configuration
# Copy this file to .env and customize the values

# ====================
# SERVER SETTINGS
# ====================
NODE_ENV=production
PORT=3000
DOMAIN=localhost
# For production, set DOMAIN to your actual domain (e.g., kwln.org)

SITE_TITLE=Kowloon
# The name of your server/instance

# ====================
# SECURITY
# ====================
JWT_SECRET=changeme_random_secret_key
# IMPORTANT: Generate a secure random string for production!
# You can use: openssl rand -base64 32

# ====================
# ADMIN SETTINGS
# ====================
ADMIN_EMAIL=admin@localhost
# Email address for the admin account

ADMIN_PASSWORD=changeme
# Change this to a secure password!

# ====================
# DATABASE SETTINGS
# ====================
MONGO_USERNAME=kowloon
MONGO_PASSWORD=kowloon_password
# Change to a secure password for production!
MONGO_DATABASE=kowloon

# Port mapping for MongoDB
# If you have MongoDB running locally on 27017, change this to avoid conflicts
# Example: MONGO_HOST_PORT=27018 to expose Docker MongoDB on port 27018
MONGO_HOST_PORT=27017

# ====================
# S3/MINIO STORAGE
# ====================
S3_REGION=us-east-1
# S3_ENDPOINT: MinIO endpoint inside Docker is set per-server in docker-compose.yml.
# For running outside Docker against a local MinIO, set this to http://localhost:9000.
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=kowloon
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
# IMPORTANT: Change access key and secret key for production!

# S3_PUBLIC_URL - URL where uploaded files are publicly accessible.
# In Docker: overridden per-server in docker-compose.yml (http://localhost:9000/kwln1 etc.)
# Outside Docker / single-server: http://localhost:9000/<bucket>
# Production: https://files.your-domain.com/<bucket>
S3_PUBLIC_URL=http://localhost:9000/kowloon

# MinIO port mappings (host-side)
MINIO_API_PORT=9000      # S3 API — http://localhost:9000
MINIO_CONSOLE_PORT=9001  # Web console — http://localhost:9001

# ====================
# DEBUGGING (Optional)
# ====================
# ROUTE_DEBUG=1
# Uncomment to enable route debugging output
