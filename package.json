{
  "name": "kowloon",
  "type": "module",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "setup": "node setup.js",
    "worker:feed": "node workers/feedFanOut.js",
    "test": "NODE_OPTIONS=--experimental-vm-modules jest --runInBand",
    "test:unit": "NODE_OPTIONS=--experimental-vm-modules jest tests/unit --runInBand",
    "test:int": "NODE_OPTIONS=--experimental-vm-modules jest tests/integration --runInBand",
    "dev:local": "pm2 start ecosystem.local.config.cjs",
    "dev:local:stop": "pm2 stop ecosystem.local.config.cjs",
    "dev:local:delete": "pm2 delete ecosystem.local.config.cjs",
    "dev:local:logs": "pm2 logs kwln1 kwln2 kwln3",
    "dev:caddy": "sudo caddy run --config Caddyfile.local"
  },
  "imports": {
    "#kowloon": "./Kowloon.js",
    "#schema": "./schema/index.js",
    "#schema/*": "./schema/*",
    "#methods/*": "./methods/*",
    "#utils/*": "./methods/utils/*",
    "#routes": "./routes/index.js",
    "#routes/*": "./routes/*",
    "#ActivityParser": "./ActivityParser/index.js",
    "#ActivityParser/*": "./ActivityParser/*",
    "#config/*": "./config/*"
  },
  "author": "Joshua Ellis",
  "license": "ISC",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.758.0",
    "@aws-sdk/lib-storage": "^3.758.0",
    "@aws-sdk/s3-request-presigner": "^3.758.0",
    "ajv": "^8.18.0",
    "ajv-formats": "^3.0.1",
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "file-type": "^22.0.1",
    "jose": "^6.0.11",
    "link-preview-js": "^3.0.5",
    "marked": "^12.0.2",
    "mime-types": "^2.1.35",
    "mongoose": "^8.3.5",
    "multer": "^2.1.1",
    "nocache": "^4.0.0",
    "nodemailer": "^8.0.5",
    "qrcode": "^1.5.4",
    "random-words": "^2.0.1",
    "sanitize-html": "^2.17.3",
    "serve-static": "^2.2.1",
    "sharp": "^0.34.5",
    "winston": "^3.14.2"
  },
  "overrides": {
    "follow-redirects": "^1.16.0",
    "brace-expansion": "^5.0.5",
    "fast-xml-parser": "^5.7.0",
    "uuid": ">=14.0.0",
    "http-proxy-agent": "^7.0.2",
    "minimatch": "^10.2.4",
    "qs": "^6.15.0",
    "js-yaml": "^4.1.1",
    "path-to-regexp": "^0.1.13",
    "picomatch": "^2.3.2",
    "yauzl": "^3.2.1"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.0.0",
    "jest": "^29.7.0",
    "mongodb-memory-server": "^10.2.3"
  }
}
